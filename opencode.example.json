{
  "$schema": "https://opencode.ai/config.json",
  "model": "verda/mistralai/Devstral-Small-2-24B-Instruct-2512",
  "provider": {
    "verda": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Verda (Devstral)",
      "options": {
        "baseURL": "<YOUR_VERDA_API_URL>/v1",
        "apiKey": "{env:VERDA_API_KEY}"
      },
      "models": {
        "mistralai/Devstral-Small-2-24B-Instruct-2512": {
          "name": "Devstral Small 2 (Verda)",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        }
      }
    },
    "mistral": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mistral API",
      "options": {
        "baseURL": "https://api.mistral.ai/v1",
        "apiKey": "{env:MISTRAL_API_KEY}"
      },
      "models": {
        "devstral-small-latest": {
          "name": "Devstral Small 2 (Mistral API)",
          "limit": {
            "context": 256000,
            "output": 8192
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "devstral-small-2-32k": {
          "name": "Devstral Small 2 (local)",
          "tools": true
        }
      }
    }
  }
}
