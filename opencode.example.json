{
  "$schema": "https://opencode.ai/config.json",
  "model": "verda-rtx-pro-6000/mistralai/Devstral-Small-2-24B-Instruct-2512",
  "provider": {
    "verda-a100-40gb": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Verda A100 40GB",
      "options": {
        "baseURL": "<YOUR_VERDA_API_URL>/v1",
        "apiKey": "{env:VERDA_API_KEY}"
      },
      "models": {
        "mistralai/Devstral-Small-2-24B-Instruct-2512": {
          "name": "Devstral Small 2 (A100 40GB)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    },
    "verda-a100-80gb": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Verda A100 80GB",
      "options": {
        "baseURL": "<YOUR_VERDA_API_URL>/v1",
        "apiKey": "{env:VERDA_API_KEY}"
      },
      "models": {
        "mistralai/Devstral-Small-2-24B-Instruct-2512": {
          "name": "Devstral Small 2 (A100 80GB)",
          "limit": {
            "context": 98304,
            "output": 8192
          }
        }
      }
    },
    "verda-rtx-pro-6000": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Verda RTX PRO 6000",
      "options": {
        "baseURL": "<YOUR_VERDA_API_URL>/v1",
        "apiKey": "{env:VERDA_API_KEY}"
      },
      "models": {
        "mistralai/Devstral-Small-2-24B-Instruct-2512": {
          "name": "Devstral Small 2 (RTX PRO 6000)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    },
    "mistral": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mistral API",
      "options": {
        "baseURL": "https://api.mistral.ai/v1",
        "apiKey": "{env:MISTRAL_API_KEY}"
      },
      "models": {
        "devstral-small-latest": {
          "name": "Devstral Small 2 (Mistral API)",
          "limit": {
            "context": 256000,
            "output": 8192
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "devstral-small-2-32k": {
          "name": "Devstral Small 2 (local 32k)",
          "tools": true
        },
        "devstral-small-2-98k": {
          "name": "Devstral Small 2 (local 98k)",
          "tools": true
        }
      }
    },
    "mlx-8bit": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX 8-bit (local)",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "mlx-community/Devstral-Small-2-24B-Instruct-2512-8bit": {
          "name": "Devstral Small 2 (MLX 8-bit)",
          "tools": true
        }
      }
    },
    "mlx-4bit": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX 4-bit (local)",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "mlx-community/Devstral-Small-2-24B-Instruct-2512-4bit": {
          "name": "Devstral Small 2 (MLX 4-bit)",
          "tools": true
        }
      }
    }
  }
}
